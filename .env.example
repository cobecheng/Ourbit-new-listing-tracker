# Ourbit source. This section ID is "Listing Information".
OURBIT_BASE_URL=https://www.ourbit.com
OURBIT_SECTION_ID=15425930840735
OURBIT_LOCALE=en-US
OURBIT_PAGE_SIZE=30
OURBIT_MAX_PAGES=2
OURBIT_INCLUDE_DETAILS=true

# Defaults send only listing announcements and skip delisting announcements.
OURBIT_TITLE_INCLUDE_REGEX=\b(will\s+list|listed|new\s+listing)\b
OURBIT_TITLE_EXCLUDE_REGEX=\b(delist|delisted|delisting)\b

# Polling and local state.
POLL_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=20
STATE_DB_PATH=state/ourbit_listing_tracker.sqlite3
LOG_LEVEL=INFO

# Telegram bot config. Keep these out of git.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=false
TELEGRAM_DISABLE_NOTIFICATION=false
TELEGRAM_SEND_DELAY_SECONDS=0.5
